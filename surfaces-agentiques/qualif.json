  "profiles": [
    {
      "id": "explorer",
      "label": "Explorer",
      "anchor": [20, 25, 30, 15, 25, 30],
      "verdict": "Phase d'exploration. Le risque principal est d'investir dans un régime avant d'avoir un cas d'usage à valeur claire — la surface mange le modèle, pas l'inverse.",
      "recos": [
        "Avant le tooling : cadrer 1-2 cas d'usage à valeur claire.",
        "Lire §1 (surface mange modèle) puis §10 (matrice de décision) avant de choisir.",
        "Le régime décide, pas le modèle."
      ]
    },
    {
      "id": "chatbot-trapped",
      "label": "Chatbot-trapped",
      "anchor": [40, 35, 50, 35, 40, 40],
      "verdict": "Vous avez un chatbot qui patine sur les cas d'usage utiles. Le procès du chatbot vous concerne directement — le coupable est rarement le modèle, c'est le régime.",
      "recos": [
        "Lire §2 (procès du chatbot) avant d'investir davantage dans cette surface.",
        "Choisir un régime plus intégré : copilote inline (§3), canvas (§4) ou narratif (§5).",
        "Mettre en place observabilité conversation + eval offline (§8) avant de scaler.",
        "Couper le chatbot ouvert sur les use cases qui ont un régime alternatif viable."
      ]
    },
    {
      "id": "builder",
      "label": "Builder / Scaler",
      "anchor": [65, 70, 70, 65, 65, 50],
      "verdict": "Vous construisez un régime intégré. L'enjeu n'est plus de prouver — c'est de choisir entre AG-UI (standard) et SDK propriétaire, et d'industrialiser sans fragmenter.",
      "recos": [
        "Voir §7 — AG-UI vs SDK : préserver la portabilité du runtime.",
        "Convergence sur une architecture canonique (§9) : un socle, un protocole, des régimes.",
        "Eval conversation centrale (§8) — pas un eval par régime.",
        "Patterns de confiance (§8) en J0, pas en plan."
      ]
    },
    {
      "id": "regulated",
      "label": "Regulated",
      "anchor": [50, 50, 55, 50, 60, 85],
      "verdict": "Votre première contrainte n'est pas technique — elle est réglementaire. Traçabilité conversation + AI Act redéfinissent le périmètre du faisable, et le régime on-behalf-of est probablement à différer.",
      "recos": [
        "Démarrer par §8 (gouvernance) avant de choisir le régime.",
        "On-behalf-of (§6) en sandbox uniquement tant que la traçabilité n'est pas industrielle.",
        "Stocker la conversation complète comme artefact d'audit, pas seulement le résultat.",
        "AG-UI (§7) facilite l'audit : événements typés > stream texte opaque.",
        "Eval offline obligatoire avant tout déploiement client-facing."
      ]
    },
    {
      "id": "pioneer",
      "label": "Pioneer on-behalf-of",
      "anchor": [80, 85, 80, 80, 80, 60],
      "verdict": "Vous êtes à la frontière du régime on-behalf-of et de A2A. Le risque n'est pas de manquer la techno mais d'investir dans l'interop avant que les standards UX stabilisent.",
      "recos": [
        "AG-UI (§7) en production, A2A en sandbox contrôlée.",
        "Surface on-behalf-of (§6) traitée comme produit interne, pas comme feature.",
        "Contribution upstream AG-UI / MCP — vous êtes en position de le faire.",
        "Patterns de confiance (§8) en proxy obligatoire entre agent et tooling externe."
      ]
    }
  ],
  "adjustments": [
    {
      "id": "frein-hallucination",
      "when": { "axis": "maturite-ia", "input": "freins", "contains": "hallucinations" },
      "reco": "Voir §8 (patterns de confiance) — sortir du chatbot brut pour un régime contraint est souvent la solution, pas un meilleur prompt."
    },
    {
      "id": "frein-ergonomie",
      "when": { "axis": "maturite-ia", "input": "freins", "contains": "ergonomie" },
      "reco": "Voir §3-5 (copilote / canvas / narratif) — l'ergonomie se gagne sur le régime, rarement sur la qualité de réponse."
    },
    {
      "id": "frein-tracabilite",
      "when": { "axis": "maturite-ia", "input": "freins", "contains": "tracabilite" },
      "reco": "Voir §7 — AG-UI standardise les événements typés (TextMessage / ToolCall / State), bien plus auditable qu'un stream texte opaque."
    },
    {
      "id": "frein-deraillements",
      "when": { "axis": "maturite-ia", "input": "freins", "contains": "deraillements" },
      "reco": "Voir §8 — un proxy outils obligatoire entre l'agent et le système (allow-list, dry-run, human-in-the-loop sur les tools dangereux) coupe la grande majorité des incidents."
    },
    {
      "id": "surface-chatbot",
      "when": { "axis": "maturite-ia", "input": "surface-actuelle", "equals": "chatbot" },
      "reco": "Lisez §2 (procès du chatbot) avant d'investir davantage dans cette surface — il y a probablement un régime mieux adapté pour vos use cases utiles."
    },
    {
      "id": "regime-on-behalf-of",
      "when": { "axis": "cas-usage", "input": "regime-cible", "equals": "on-behalf-of" },
      "reco": "Voir §6 + §7 — investir AG-UI dès le PoC : l'autonomie sans traçabilité événementielle devient intenable au premier audit."
    },
    {
      "id": "regime-indecis",
      "when": { "axis": "cas-usage", "input": "regime-cible", "equals": "indecis" },
      "reco": "Voir §10 (matrice de décision) — le choix du régime se déduit du cas d'usage, pas l'inverse."
    },
    {
      "id": "runtime-indecis",
      "when": { "axis": "environnement", "input": "runtime", "contains": "indecis-runtime" },
      "reco": "Voir §7 — un runtime aligné AG-UI (CopilotKit, Mastra) préserve la liberté de migration ; un SDK propriétaire engage."
    },
    {
      "id": "surface-mobile",
      "when": { "axis": "environnement", "input": "surfaces-deployees", "contains": "mobile" },
      "reco": "Le régime copilote inline (§3) est plus difficile à porter sur mobile que le canvas génératif (§4) — la contrainte écran change le choix."
    },
    {
      "id": "rgpd-customer-facing",
      "when": {
        "axis": "cas-usage",
        "input": "domaines",
        "contains": "customer-facing",
        "and": { "axis": "gouvernance", "input": "contraintes", "contains": "rgpd" }
      },
      "reco": "Le régime narratif (§5) découple session conversationnelle et données client — souvent plus simple à conformer que le chatbot ouvert customer-facing."
    },
    {
      "id": "contrainte-ai-act",
      "when": { "axis": "gouvernance", "input": "contraintes", "contains": "ai-act" },
      "reco": "Échéance 2 août 2026 pour l'Annexe III — un agent on-behalf-of qui agit en autonomie sur un workflow décisionnel est à requalifier en haut-risque par défaut."
    },
    {
      "id": "contrainte-souverainete",
      "when": { "axis": "gouvernance", "input": "contraintes", "contains": "souverainete" },
      "reco": "AG-UI (§7) est protocole-agnostique côté runtime — vous pouvez le brancher sur un LLM souverain (Mistral, Albert) sans changer la surface."
    },
    {
      "id": "equipe-vide-maturite-haute",
      "when": {
        "axis": "equipe",
        "input": "structure",
        "lt": 25,
        "and": { "axis": "maturite-ia", "input": "stade", "gte": 50 }
      },
      "reco": "Vos PoC sont en avance sur l'organisation — staffer un squad front+agent (3-5 ETP) avant de scaler, sinon dette opérationnelle garantie."
    },
    {
      "id": "budget-frileux-maturite-haute",
      "when": {
        "axis": "budget",
        "input": "posture",
        "equals": "frileux",
        "and": { "axis": "maturite-ia", "input": "stade", "gte": 50 }
      },
      "reco": "Le coût du régime cible (front + agent + obs) est de loin le poste majoritaire — pas le LLM. Réviser la posture si la maturité est déjà ≥ Pilote."
    },
    {
      "id": "urgence-haute-maturite-basse",
      "when": {
        "axis": "cas-usage",
        "input": "urgence",
        "gte": 75,
        "and": { "axis": "maturite-ia", "input": "stade", "lt": 25 }
      },
      "reco": "L'urgence ne s'aligne pas avec votre maturité — risque de PoC promu en prod sans patterns de confiance (§8) ni eval centrale."
    }
  ]
}
