        {
          "id": "freins",
          "type": "multi",
          "label": "Principaux freins ressentis",
          "max_picks": 3,
          "options": [
            { "id": "hallucinations", "label": "Hallucinations" },
            { "id": "ergonomie", "label": "Ergonomie / UX" },
